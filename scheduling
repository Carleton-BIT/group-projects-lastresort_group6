<div class="popup-container">

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
        }

        /* BACKGROUND IMAGE STRIP (TOP) */
        .header-images {
            display: flex;
            width: 100%;
            height: 150px;
            border-bottom: 4px solid darkred;
            background-color: black;
        }

        .header-images img {
            flex: 1;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* BACKGROUND SLIDESHOW */
        .gym-slideshow {
            position: fixed;
            top: 150px;
            left: 0;
            width: 100%;
            height: calc(100% - 150px);
            z-index: -1;
            overflow: hidden;
        }

        .gym-slideshow img {
            position: absolute;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.3; /* dim background */
            animation: fadeSlide 12s infinite;
        }

        .gym-slideshow img:nth-child(1){ animation-delay: 0s; }
        .gym-slideshow img:nth-child(2){ animation-delay: 4s; }
        .gym-slideshow img:nth-child(3){ animation-delay: 8s; }

        @keyframes fadeSlide {
            0%   { opacity:0; }
            10%  { opacity:0.3; }
            30%  { opacity:0.3; }
            40%  { opacity:0; }
            100% { opacity:0; }
        }

        /* CENTER POPUP */
        .popup {
            position: absolute;
            top: 55%;
            left: 50%;
            transform: translate(-50%, -50%);
            background-color: rgb(14, 13, 13);
            border: 3px solid darkred;
            border-radius: 10px;
            padding: 20px;
            width: 320px;
            text-align: center;
            color: black;
            z-index: 2;
        }

        .popup h3 {
            color: red;
        }

        .popup label {
            color: #ff4d4d;
            font-weight: bold;
        }

        .popup input[type="datetime-local"] {
            border: 2px solid red;
            border-radius: 5px;
            padding: 6px;
            width: 85%;
            background-color: white;
            color: black;
        }

        .popup button {
            background-color: darkred;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        .popup button:hover {
            background-color: red;
        }

        .close {
            float: right;
            text-decoration: none;
            font-size: 18px;
            color: red;
            font-weight: bold;
        }

        .close:hover {
            color: white;
        }

        /* Submit button styling */
        .submit-button button {
            background-color: darkred;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

        .submit-button button:hover {
            background-color: red;
        }
    </style>

    <!-- TOP IMAGE STRIP -->
    <div class="header-images">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRTwfEzZ63TFZCYGdPA7cT1Jt2KiM7ZvQ7l0A&s">
        <img src="https://media.istockphoto.com/id/2027278927/photo/young-athletic-woman-exercising-with-barbell-during-sports-training-in-a-gym.jpg?s=612x612&w=0&k=20&c=ifFL7Mqc8NwTj25PAx4ONy1OOQZvc1S_kVOofsbLgFw=">
        <img src="https://images.ctfassets.net/8urtyqugdt2l/67ll4VrY53hDXLti1zIqd/90113e96e96e0177abc0897564dd9bdb/sled-push-desktop.jpg">
        <img src="https://i0.wp.com/www.muscleandfitness.com/wp-content/uploads/2018/03/1109-lifting-bench-press-spotter.jpg?quality=86&strip=all">
        <img src="https://simplifaster.com/wp-content/uploads/2025/06/Med-Ball-Squat.jpg">
    </div>

    <!-- BACKGROUND SLIDESHOW -->
    <div class="gym-slideshow">
        <img src="https://carleton.ca/hr/wp-content/uploads/sites/16/fitness-centre-e1420663592197.jpg">
        <img src="https://students.carleton.ca/wp-content/uploads/2022/05/Web-post-size-600-x-400-25.png">
        <img src="https://static.where-e.com/Canada/Carleton-University-Raven-S-Nest_3bfc6460e95524486ed0acbcf3e4bc2a.jpg">
    </div>

    <!-- POPUP -->
    <div id="time" class="popup">

        <a href="check.html" class="close">✖</a>

        <h3>Select Time</h3>

        <label for="appointment">Select Date & Time:</label><br>
        <input type="datetime-local" id="appointment" required>

        <br><br>

        <!-- Button goes directly to check.html if input is filled -->
        <button type="button" id="submitBtn">Submit</button>

    </div>

    <!-- JAVASCRIPT TO KEEP REQUIRED VALIDATION -->
    <script>
        const submitBtn = document.getElementById("submitBtn");
        const dateInput = document.getElementById("appointment");

        submitBtn.addEventListener("click", () => {
            if (!dateInput.value) {
                // Show "please fill out this field" browser message
                dateInput.reportValidity();
                return;
            }
            // Redirect to main page if input is filled
            window.location.href = "check.html";
        });
    </script>

</div>